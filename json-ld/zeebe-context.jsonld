{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "zeebe": "https://docs.camunda.io/docs/apis-tools/zeebe-api-rest/",
    "bpmn": "https://www.omg.org/spec/BPMN/",

    "ProcessInstance": {
      "@id": "zeebe:ProcessInstance",
      "@type": "@id"
    },
    "Job": {
      "@id": "zeebe:Job",
      "@type": "@id"
    },
    "Deployment": {
      "@id": "zeebe:Deployment",
      "@type": "@id"
    },
    "Incident": {
      "@id": "zeebe:Incident",
      "@type": "@id"
    },
    "Message": {
      "@id": "zeebe:Message",
      "@type": "@id"
    },
    "Signal": {
      "@id": "zeebe:Signal",
      "@type": "@id"
    },
    "UserTask": {
      "@id": "zeebe:UserTask",
      "@type": "@id"
    },

    "processInstanceKey": {
      "@id": "zeebe:processInstanceKey",
      "@type": "schema:identifier"
    },
    "processDefinitionKey": {
      "@id": "zeebe:processDefinitionKey",
      "@type": "schema:identifier"
    },
    "bpmnProcessId": {
      "@id": "bpmn:processId",
      "@type": "schema:Text"
    },
    "version": {
      "@id": "schema:version",
      "@type": "schema:Integer"
    },
    "tenantId": {
      "@id": "zeebe:tenantId",
      "@type": "schema:Text"
    },
    "jobKey": {
      "@id": "zeebe:jobKey",
      "@type": "schema:identifier"
    },
    "type": {
      "@id": "zeebe:jobType",
      "@type": "schema:Text"
    },
    "retries": {
      "@id": "zeebe:retries",
      "@type": "schema:Integer"
    },
    "worker": {
      "@id": "zeebe:worker",
      "@type": "schema:Text"
    },
    "deadline": {
      "@id": "zeebe:deadline",
      "@type": "schema:DateTime"
    },
    "variables": {
      "@id": "zeebe:variables",
      "@type": "@json"
    },
    "customHeaders": {
      "@id": "zeebe:customHeaders",
      "@type": "@json"
    },
    "elementId": {
      "@id": "bpmn:elementId",
      "@type": "schema:Text"
    },
    "correlationKey": {
      "@id": "zeebe:correlationKey",
      "@type": "schema:Text"
    },
    "signalName": {
      "@id": "zeebe:signalName",
      "@type": "schema:Text"
    },
    "incidentKey": {
      "@id": "zeebe:incidentKey",
      "@type": "schema:identifier"
    },
    "userTaskKey": {
      "@id": "zeebe:userTaskKey",
      "@type": "schema:identifier"
    },
    "assignee": {
      "@id": "schema:assignee",
      "@type": "schema:Text"
    },
    "deploymentKey": {
      "@id": "zeebe:deploymentKey",
      "@type": "schema:identifier"
    },
    "clusterSize": {
      "@id": "zeebe:clusterSize",
      "@type": "schema:Integer"
    },
    "partitionsCount": {
      "@id": "zeebe:partitionsCount",
      "@type": "schema:Integer"
    },
    "replicationFactor": {
      "@id": "zeebe:replicationFactor",
      "@type": "schema:Integer"
    },
    "gatewayVersion": {
      "@id": "zeebe:gatewayVersion",
      "@type": "schema:Text"
    }
  }
}
